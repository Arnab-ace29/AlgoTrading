# ══════════════════════════════════════════════════════════════════════════════
# UPSTOX API CREDENTIALS
# developer.upstox.com → your app → API Keys tab
#
# HOW TO SWITCH MODES:
#   Change UPSTOX_MODE below — that's the ONLY line you ever need to edit.
#   Both sandbox and live credentials live here permanently.
#   scripts/refresh_token.py auto-fills the correct _ACCESS_TOKEN for the
#   active mode.
# ══════════════════════════════════════════════════════════════════════════════

# ── Mode switch ───────────────────────────────────────────────────────────────
# sandbox = safe testing, no real money
# live    = real trades, real capital — triple-check before switching
UPSTOX_MODE=sandbox

# ── Sandbox credentials (developer.upstox.com → Sandbox app) ──────────────────
# Token valid 30 days. Re-generate from portal → Generate button.
# Sandbox tokens work for: historical data, Place/Modify/Cancel orders.
# Sandbox tokens do NOT work for: WebSocket, LTP quotes, profile, portfolio.
SANDBOX_API_KEY=your_sandbox_api_key_here
SANDBOX_API_SECRET=your_sandbox_api_secret_here
SANDBOX_REDIRECT_URI=http://127.0.0.1
SANDBOX_ACCESS_TOKEN=your_sandbox_access_token_here

# ── Live credentials (developer.upstox.com → Live/Algotrading app) ────────────
# Token expires daily at midnight IST. Run scripts/refresh_token.py each morning.
# WARNING: Real money. Verify paper trading works before switching mode to live.
LIVE_API_KEY=your_live_api_key_here
LIVE_API_SECRET=your_live_api_secret_here
LIVE_REDIRECT_URI=http://127.0.0.1
LIVE_ACCESS_TOKEN=

# ── Analytics Token (for backfill & screener — preferred over live token) ──────
# Lifetime: 1 year. Read-only: historical data + market data. Cannot place orders.
# Use this for all unattended jobs (backfill, screener, RL training) — never expires mid-run.
# Generate at: developer.upstox.com → Your App → Analytics tab → Generate Token
# Command to backfill 2 years × 750 symbols:
#   python data/upstox_history.py --universe --days 730 --tf 5min
ANALYTICS_TOKEN=

# ── OpenAlgo ──────────────────────────────────────────────────────────────────
# OpenAlgo runs locally on port 3000 (https://github.com/marketcalls/openalgo)
# Only needed when going live — skip for sandbox testing
OPENALGO_HOST=http://127.0.0.1:3000
OPENALGO_API_KEY=your_openalgo_api_key_here

# ── System ────────────────────────────────────────────────────────────────────
# Path to the SQLite (WAL) operational database file
DB_PATH=data/algo_trading.sqlite

# Active risk profile: LOW / MEDIUM / HIGH
RISK_PROFILE=LOW

# Trading capital in INR (used for position sizing and daily loss limits)
TRADING_CAPITAL=20000

# MIS Margin leverage (USE_MARGIN=true scales position sizes using broker multipliers)
# Populate cache first: python scripts/fetch_margin_multipliers.py (needs live token)
# MAX_MIS_LEVERAGE caps the leverage even if the broker allows more (safety ceiling)
USE_MARGIN=false
MAX_MIS_LEVERAGE=5.0

# Set to true to run in paper/sandbox mode (no real orders placed via OpenAlgo)
# Keep this true even in sandbox — it adds an extra layer of safety
PAPER_TRADE=true

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_API_PORT=8000
DASHBOARD_SECRET_KEY=change_this_to_a_random_string
# Shared secret for dashboard MUTATING requests (kill switch, mode/token, close-all,
# backtest run, ...). Sent by the UI as the X-API-Key header. Leave EMPTY for localhost
# dev (auth disabled); SET a strong random value before exposing the dashboard anywhere.
DASHBOARD_TOKEN=

# ── Discord Notifications ─────────────────────────────────────────────────────
# Create a Discord server → each channel → Edit Channel → Integrations → Webhooks → New Webhook → Copy URL
# Leave blank to disable that channel's notifications

# Fired on every new trade entry
DISCORD_WEBHOOK_TRADES=

# Fired on every trade exit (includes P&L)
DISCORD_WEBHOOK_EXITS=

# EOD daily summary (win rate, total P&L, charges breakdown)
DISCORD_WEBHOOK_DAILY=

# Circuit breaker triggers, kill switch, risk limit breaches
DISCORD_WEBHOOK_ALERTS=

# System errors, exceptions, connectivity issues
DISCORD_WEBHOOK_ERRORS=

# Verbose debug/info logs (optional, can leave blank)
DISCORD_WEBHOOK_LOGS=
